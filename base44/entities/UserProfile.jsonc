{
  "name": "UserProfile",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "description": "ID of the authenticated user"
    },
    "user_email": {
      "type": "string",
      "description": "Email of the user"
    },
    "username": {
      "type": "string",
      "description": "Username for search and display"
    },
    "full_name": {
      "type": "string",
      "description": "Full name of the user"
    },
    "bio": {
      "type": "string",
      "description": "User bio"
    },
    "profile_photo": {
      "type": "string",
      "description": "URL to profile photo"
    },
    "venmo": {
      "type": "string",
      "description": "Venmo username e.g. @username"
    },
    "cashapp": {
      "type": "string",
      "description": "Cash App handle e.g. $cashtag"
    },
    "paypal": {
      "type": "string",
      "description": "PayPal.me link or username"
    },
    "zelle": {
      "type": "string",
      "description": "Zelle phone or email"
    },
    "instagram": {
      "type": "string",
      "description": "Instagram handle"
    },
    "twitter": {
      "type": "string",
      "description": "X / Twitter handle"
    },
    "tiktok": {
      "type": "string",
      "description": "TikTok handle"
    },
    "snapchat": {
      "type": "string",
      "description": "Snapchat username"
    }
  },
  "required": [
    "user_id",
    "user_email"
  ]
}